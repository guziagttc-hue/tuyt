{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string", "description": "Display username" },
        "displayName": { "type": "string", "description": "Display name" },
        "avatarUrl": { "type": "string", "description": "URL to avatar image" },
        "bio": { "type": "string", "description": "User bio" },
        "createdAt": { "type": "string", "format": "date", "description": "Account creation date" }
      },
      "required": ["uid", "username", "displayName"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profiles collection"
    }
  }
}
