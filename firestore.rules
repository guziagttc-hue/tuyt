rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - username: string (required, 3-30 chars) - Display username
    //   - displayName: string (required, 1-50 chars) - Display name
    //   - avatarUrl: string (optional, URL) - URL to avatar image
    //   - bio: string (optional, < 500 chars) - User bio
    //   - createdAt: timestamp (required) - Account creation date
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }

    function isOwner(uid) {
       return isAuthenticated() && request.auth.uid == uid;
    }

    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
       return request.resource.data[field] is string &&
         request.resource.data[field].size() >= minLen &&
         request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
       return url is string &&
         (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // Domain Validator
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'username', 'displayName', 'avatarUrl', 'bio', 'createdAt']) &&
             data.uid is string &&
             isValidString('username', 3, 30) &&
             isValidString('displayName', 1, 50) &&
             (!('avatarUrl' in data) || isValidUrl(data.avatarUrl)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated(); // Public profiles for now, but sensitive fields should be separated
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.uid == uid;
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && areImmutableFieldsUnchanged(['uid', 'createdAt']);
      allow delete: if false;
    }
  }
}
